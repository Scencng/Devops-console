# Timezone
TZ=Asia/Shanghai

# Exposed ports on the Linux host
FRONTEND_BIND=0.0.0.0
FRONTEND_PORT=80
FRONTEND_METRICS_PROXY_BIND=127.0.0.1
FRONTEND_METRICS_PROXY_PORT=9200
BACKEND_BIND=0.0.0.0
BACKEND_PORT=8081
BACKEND_METRICS_BIND=127.0.0.1
BACKEND_METRICS_PORT=9090
MYSQL_BIND=127.0.0.1
MYSQL_PORT=3306
REDIS_BIND=127.0.0.1
REDIS_PORT=6379

# Base images
MYSQL_IMAGE=mysql:8.0
REDIS_IMAGE=redis:7-alpine

# MySQL
MYSQL_ROOT_PASSWORD=ChangeThisMysqlRootPassword
MYSQL_DATABASE=kafka_console

# Redis
REDIS_PASSWORD=ChangeThisRedisPassword

# Backend runtime config written by deploy.sh
JWT_SECRET=ChangeThisJwtSecretToALongRandomString
# If Prometheus runs on the same Linux host outside this compose stack,
# this default works because docker-compose.yml adds host.docker.internal.
PROMETHEUS_BASE_URL=http://host.docker.internal:9090
SERVER_LOG_LEVEL=info
SWAGGER_ENABLED=false
SWAGGER_HOST=localhost:8081
HEALTH_INTERVAL=30

# Deployment behavior
INIT_DB=true
FORCE_INIT_DB=false

# For host Nginx reverse proxy + HTTPS:
# FRONTEND_BIND=127.0.0.1
# FRONTEND_PORT=8088
# BACKEND_BIND=127.0.0.1
